# Server
PORT=8080
APP_ENV=development

# Frontend integration
# SPA base URL the OAuth callback redirects to (tokens land at FRONTEND_URL/auth/callback#...)
FRONTEND_URL=http://localhost:5173
# CORS allow-list (comma-separated). Dev uses the Vite proxy, so this matters in production.
ALLOWED_ORIGINS=http://localhost:5173

# Database (required)
DATABASE_URL=postgres://tbd:tbd@localhost:5434/tbd_reforger?sslmode=disable

# Auth (required)
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_MIN=15

# Discord OAuth2 + role sync
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URL=http://localhost:8080/api/v1/auth/discord/callback
DISCORD_GUILD_ID=
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

# Game-server telemetry ingest auth
SERVICE_TOKEN=change-me-service-token

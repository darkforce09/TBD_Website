# API base. Default uses the Vite dev proxy (see vite.config.ts).
# WARNING: the Vite/http-proxy dev proxy drops large POST bodies (~2 MB+), which the browser
# reports as ERR_NETWORK with no HTTP response. Large Mission Creator version saves (~360k slots,
# hundreds of MB) auto-bypass the proxy and POST straight to the API in dev (E3b); CORS already
# allows http://localhost:5173 via the root .env ALLOWED_ORIGINS. No env change is needed for that.
#   VITE_API_DIRECT_URL=http://localhost:8080/api/v1   # override the auto-bypass target (optional)
#   VITE_API_URL=http://localhost:8080/api/v1          # route ALL API calls direct (restart make web)
VITE_API_URL=/api/v1
VITE_DEFAULT_SERVER_NAME=TBD Main
